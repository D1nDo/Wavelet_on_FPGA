# Proc to create BD all_levels_blocks
proc cr_bd_all_levels_blocks { parentCell } {
# The design that will be created by this Tcl proc contains the following 
# module references:
# Axis_Db4_decomposer, Axis_data_and_valid_delay, Axis_Db4_reconstruction, Axis_data_and_valid_delay, Axis_Db4_decomposer, Axis_Db4_decomposer, Axis_Db4_reconstruction, Axis_Db4_reconstruction, Axis_Hard_threshold_fixed, Axis_Hard_threshold_fixed, Axis_Hard_threshold_fixed, Axis_Db4_decomposer, Axis_data_and_valid_delay, Axis_Db4_reconstruction, Axis_Db4_decomposer, Axis_Db4_reconstruction, Axis_Hard_threshold_fixed, Axis_Hard_threshold_fixed, Axis_Db4_decomposer, Axis_Db4_reconstruction, Axis_Hard_threshold_fixed



  # CHANGE DESIGN NAME HERE
  set design_name all_levels_blocks

  common::send_gid_msg -ssname BD::TCL -id 2010 -severity "INFO" "Currently there is no design <$design_name> in project, so creating one..."

  create_bd_design $design_name

  set bCheckIPsPassed 1
  ##################################################################
  # CHECK Modules
  ##################################################################
  set bCheckModules 1
  if { $bCheckModules == 1 } {
     set list_check_mods "\ 
  Axis_Db4_decomposer\
  Axis_data_and_valid_delay\
  Axis_Db4_reconstruction\
  Axis_data_and_valid_delay\
  Axis_Db4_decomposer\
  Axis_Db4_decomposer\
  Axis_Db4_reconstruction\
  Axis_Db4_reconstruction\
  Axis_Hard_threshold_fixed\
  Axis_Hard_threshold_fixed\
  Axis_Hard_threshold_fixed\
  Axis_Db4_decomposer\
  Axis_data_and_valid_delay\
  Axis_Db4_reconstruction\
  Axis_Db4_decomposer\
  Axis_Db4_reconstruction\
  Axis_Hard_threshold_fixed\
  Axis_Hard_threshold_fixed\
  Axis_Db4_decomposer\
  Axis_Db4_reconstruction\
  Axis_Hard_threshold_fixed\
  "

   set list_mods_missing ""
   common::send_gid_msg -ssname BD::TCL -id 2020 -severity "INFO" "Checking if the following modules exist in the project's sources: $list_check_mods ."

   foreach mod_vlnv $list_check_mods {
      if { [can_resolve_reference $mod_vlnv] == 0 } {
         lappend list_mods_missing $mod_vlnv
      }
   }

   if { $list_mods_missing ne "" } {
      catch {common::send_gid_msg -ssname BD::TCL -id 2021 -severity "ERROR" "The following module(s) are not found in the project: $list_mods_missing" }
      common::send_gid_msg -ssname BD::TCL -id 2022 -severity "INFO" "Please add source files for the missing module(s) above."
      set bCheckIPsPassed 0
   }
}

  if { $bCheckIPsPassed != 1 } {
    common::send_gid_msg -ssname BD::TCL -id 2023 -severity "WARNING" "Will not continue with creation of design due to the error(s) above."
    return 3
  }

  
# Hierarchical cell: One_level
proc create_hier_cell_One_level { parentCell nameHier } {

  variable script_folder

  if { $parentCell eq "" || $nameHier eq "" } {
     catch {common::send_gid_msg -ssname BD::TCL -id 2092 -severity "ERROR" "create_hier_cell_One_level() - Empty argument(s)!"}
     return
  }

  # Get object for parentCell
  set parentObj [get_bd_cells $parentCell]
  if { $parentObj == "" } {
     catch {common::send_gid_msg -ssname BD::TCL -id 2090 -severity "ERROR" "Unable to find parent cell <$parentCell>!"}
     return
  }

  # Make sure parentObj is hier blk
  set parentType [get_property TYPE $parentObj]
  if { $parentType ne "hier" } {
     catch {common::send_gid_msg -ssname BD::TCL -id 2091 -severity "ERROR" "Parent <$parentObj> has TYPE = <$parentType>. Expected to be <hier>."}
     return
  }

  # Save current instance; Restore later
  set oldCurInst [current_bd_instance .]

  # Set parent object as current
  current_bd_instance $parentObj

  # Create cell and set as current instance
  set hier_obj [create_bd_cell -type hier $nameHier]
  current_bd_instance $hier_obj

  # Create interface pins
  create_bd_intf_pin -mode Slave -vlnv xilinx.com:interface:axis_rtl:1.0 s_axis_0

  create_bd_intf_pin -mode Master -vlnv xilinx.com:interface:axis_rtl:1.0 m_axis_0


  # Create pins
  create_bd_pin -dir I clock
  create_bd_pin -dir I -type rst reset_n

  # Create instance: Axis_Db4_decomposer_0, and set properties
  set block_name Axis_Db4_decomposer
  set block_cell_name Axis_Db4_decomposer_0
  if { [catch {set Axis_Db4_decomposer_0 [create_bd_cell -type module -reference $block_name $block_cell_name] } errmsg] } {
     catch {common::send_gid_msg -ssname BD::TCL -id 2095 -severity "ERROR" "Unable to add referenced block <$block_name>. Please add the files for ${block_name}'s definition into the project."}
     return 1
   } elseif { $Axis_Db4_decomposer_0 eq "" } {
     catch {common::send_gid_msg -ssname BD::TCL -id 2096 -severity "ERROR" "Unable to referenced block <$block_name>. Please add the files for ${block_name}'s definition into the project."}
     return 1
   }
  
  # Create instance: Axis_Db4_reconstruct_0, and set properties
  set block_name Axis_Db4_reconstruction
  set block_cell_name Axis_Db4_reconstruct_0
  if { [catch {set Axis_Db4_reconstruct_0 [create_bd_cell -type module -reference $block_name $block_cell_name] } errmsg] } {
     catch {common::send_gid_msg -ssname BD::TCL -id 2095 -severity "ERROR" "Unable to add referenced block <$block_name>. Please add the files for ${block_name}'s definition into the project."}
     return 1
   } elseif { $Axis_Db4_reconstruct_0 eq "" } {
     catch {common::send_gid_msg -ssname BD::TCL -id 2096 -severity "ERROR" "Unable to referenced block <$block_name>. Please add the files for ${block_name}'s definition into the project."}
     return 1
   }
    set_property CONFIG.LEVEL {1} $Axis_Db4_reconstruct_0


  # Create instance: Axis_Hard_threshold_0, and set properties
  set block_name Axis_Hard_threshold_fixed
  set block_cell_name Axis_Hard_threshold_0
  if { [catch {set Axis_Hard_threshold_0 [create_bd_cell -type module -reference $block_name $block_cell_name] } errmsg] } {
     catch {common::send_gid_msg -ssname BD::TCL -id 2095 -severity "ERROR" "Unable to add referenced block <$block_name>. Please add the files for ${block_name}'s definition into the project."}
     return 1
   } elseif { $Axis_Hard_threshold_0 eq "" } {
     catch {common::send_gid_msg -ssname BD::TCL -id 2096 -severity "ERROR" "Unable to referenced block <$block_name>. Please add the files for ${block_name}'s definition into the project."}
     return 1
   }
    set_property CONFIG.THRESHOLD {5000} $Axis_Hard_threshold_0


  # Create interface connections
  connect_bd_intf_net -intf_net Axis_Db4_decomposer_0_m_axis_cA [get_bd_intf_pins Axis_Db4_decomposer_0/m_axis_cA] [get_bd_intf_pins Axis_Db4_reconstruct_0/s_axis_cA]
  connect_bd_intf_net -intf_net Axis_Db4_decomposer_0_m_axis_cD [get_bd_intf_pins Axis_Db4_decomposer_0/m_axis_cD] [get_bd_intf_pins Axis_Hard_threshold_0/s_axis]
  connect_bd_intf_net -intf_net Axis_Db4_reconstruct_0_m_axis [get_bd_intf_pins m_axis_0] [get_bd_intf_pins Axis_Db4_reconstruct_0/m_axis]
  connect_bd_intf_net -intf_net Axis_Hard_threshold_0_m_axis [get_bd_intf_pins Axis_Hard_threshold_0/m_axis] [get_bd_intf_pins Axis_Db4_reconstruct_0/s_axis_cD]
  connect_bd_intf_net -intf_net Conn1 [get_bd_intf_pins Axis_Db4_decomposer_0/s_axis] [get_bd_intf_pins s_axis_0]

  # Create port connections
  connect_bd_net -net Net  [get_bd_pins clock] \
  [get_bd_pins Axis_Db4_reconstruct_0/clk] \
  [get_bd_pins Axis_Db4_decomposer_0/clk] \
  [get_bd_pins Axis_Hard_threshold_0/clk]
  connect_bd_net -net Net1  [get_bd_pins reset_n] \
  [get_bd_pins Axis_Db4_reconstruct_0/reset_n] \
  [get_bd_pins Axis_Db4_decomposer_0/reset_n] \
  [get_bd_pins Axis_Hard_threshold_0/reset_n]

  # Restore current instance
  current_bd_instance $oldCurInst
}
  
