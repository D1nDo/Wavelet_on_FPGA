  connect_bd_intf_net -intf_net Axis_Db4_decomposer_0_m_axis_cA [get_bd_intf_pins Axis_Db4_decomposer_0/m_axis_cA] [get_bd_intf_pins axis_combiner_32to32_0/s0]
